#employee controller

package com.example.employeemanagement.controller;

import com.example.employeemanagement.model.Employee;
import org.springframework.web.bind.annotation.*;

import java.util.ArrayList;
import java.util.List;

@RestController
public class EmployeeController {

    private List<Employee> employees = new ArrayList<>();

    public EmployeeController() {
        employees.add(new Employee(1L, "John", "IT", 50000));
        employees.add(new Employee(2L, "Mary", "HR", 45000));
    }

    @GetMapping("/employees")
    public List<Employee> getAllEmployees() {
        return employees;
    }

    @GetMapping("/employee/{id}")
    public Employee getEmployeeById(@PathVariable Long id) {
        return employees.stream()
                .filter(emp -> emp.getEmployeeId().equals(id))
                .findFirst()
                .orElse(null);
    }

    @PostMapping("/employee")
    public String addEmployee(@RequestBody Employee employee) {
        employees.add(employee);
        return "Employee added successfully";
    }

    @PutMapping("/employee/{id}")
    public String updateEmployee(@PathVariable Long id,
                                 @RequestBody Employee updatedEmployee) {

        for (Employee employee : employees) {
            if (employee.getEmployeeId().equals(id)) {
                employee.setEmployeeName(updatedEmployee.getEmployeeName());
                employee.setDepartment(updatedEmployee.getDepartment());
                employee.setSalary(updatedEmployee.getSalary());
                return "Employee updated successfully";
            }
        }
        return "Employee not found";
    }

    @DeleteMapping("/employee/{id}")
    public String deleteEmployee(@PathVariable Long id) {

        boolean removed = employees.removeIf(
                employee -> employee.getEmployeeId().equals(id));

        return removed
                ? "Employee deleted successfully"
                : "Employee not found";
    }
}



